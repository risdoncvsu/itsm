APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Shared Neon branch for module data exchange, e.g. STAGING.
MODULE_DB_CONNECTION=pgsql
MODULE_DB_URL=
MODULE_DB_HOST=
MODULE_DB_PORT=5432
MODULE_DB_DATABASE=
MODULE_DB_USERNAME=
MODULE_DB_PASSWORD=
MODULE_DB_CHARSET=utf8
MODULE_DB_SEARCH_PATH=public
MODULE_DB_SSLMODE=require

# Dedicated HR database. This is required: do not point it at the ITSM DB_URL.
HR_DB_CONNECTION=pgsql
HR_DB_URL=
HR_DB_HOST=
HR_DB_PORT=5432
HR_DB_DATABASE=
HR_DB_USERNAME=
HR_DB_PASSWORD=
HR_DB_CHARSET=utf8
HR_DB_SEARCH_PATH=public
HR_DB_SSLMODE=require

# Dedicated Inventory database. Do not point this at ITSM DB_URL.
INVENTORY_DB_CONNECTION=pgsql
INVENTORY_DB_URL=
INVENTORY_DB_HOST=
INVENTORY_DB_PORT=5432
INVENTORY_DB_DATABASE=
INVENTORY_DB_USERNAME=
INVENTORY_DB_PASSWORD=
INVENTORY_DB_CHARSET=utf8
INVENTORY_DB_SEARCH_PATH=public
INVENTORY_DB_SSLMODE=require

# Dedicated Procurement database. Do not point this at ITSM DB_URL.
PROCUREMENT_DB_CONNECTION=pgsql
PROCUREMENT_DB_URL=
PROCUREMENT_DB_HOST=
PROCUREMENT_DB_PORT=5432
PROCUREMENT_DB_DATABASE=
PROCUREMENT_DB_USERNAME=
PROCUREMENT_DB_PASSWORD=
PROCUREMENT_DB_CHARSET=utf8
PROCUREMENT_DB_SEARCH_PATH=public
PROCUREMENT_DB_SSLMODE=require

# Dedicated staging database for module-to-module integration data.
# This is optional, but when used it must never point at the ITSM DB_URL.
STAGING_DB_CONNECTION=pgsql
STAGING_DB_URL=
STAGING_DB_HOST=
STAGING_DB_PORT=5432
STAGING_DB_DATABASE=
STAGING_DB_USERNAME=
STAGING_DB_PASSWORD=
STAGING_DB_CHARSET=utf8
STAGING_DB_SEARCH_PATH=public
STAGING_DB_SSLMODE=require

# Set this to the hosted HR dashboard URL/path to send company admins there
# after they sign in through the shared Nexora login.
HR_MODULE_URL=
